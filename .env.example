# ===========================================
# GGH — Environment Configuration
# Copy this file to .env and adjust values
# ===========================================

# Database — SQLite for development, PostgreSQL for production
DATABASE_URL=file:./db/custom.db

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ERPNext (optional — integration disabled if not provided)
# ERP_NEXT_URL=http://localhost:8000
# ERP_NEXT_API_KEY=
# ERP_NEXT_API_SECRET=

# Map Provider (google | mapbox | osm | here)
# Default is osm (free, no API key required)
MAP_PROVIDER=osm
# GOOGLE_MAPS_API_KEY=
# MAPBOX_API_KEY=
# HERE_MAPS_API_KEY=

# Admin Authentication
ADMIN_SESSION_DURATION_HOURS=24
ADMIN_SESSION_COOKIE=ggh-admin-session
ADMIN_DEFAULT_ROLE=admin

# SMS Provider (vonage | twilio | messagebird | dev)
# In development mode, OTP is auto-verified without sending SMS
# SMS_PROVIDER=dev
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_FROM_NUMBER=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# MESSAGEBIRD_API_KEY=
# MESSAGEBIRD_FROM_NUMBER=

# Payment Providers (optional)
# PAYMOB_API_KEY=
# FAWRY_API_KEY=
# FAWRY_SECRET_KEY=
# STRIPE_API_KEY=
